# Copy this file to `.env` (git-ignored) and fill in the value.
# Loaded automatically by the justfile; used by `just publish` to push the
# WH40KRT.GameRefs reference-assembly package to GitHub Packages.
#
# A GitHub Personal Access Token (classic) with the `write:packages` scope:
#   https://github.com/settings/tokens/new?scopes=write:packages&description=RTAccess+publish+gamerefs
GH_PACKAGES_TOKEN=
