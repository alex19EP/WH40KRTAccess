<!-- Container project that packs JetBrains Refasmer-stripped game reference assemblies
     into a NuGet package for CI. It has no source and produces no assembly of its own —
     the `assemblies/` and `UnityModManager/` folders are generated by scripts/build-gamerefs.ps1
     (both git-ignored) and carried verbatim into the package. See `just refs`. -->
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <NoDefaultExcludes>true</NoDefaultExcludes>
    <SuppressDependenciesWhenPacking>true</SuppressDependenciesWhenPacking>
    <!-- NU5128: no lib/ or dependencies — intentional, this is a bag of reference DLLs.
         NU5100: DLLs live outside lib/ so NuGet won't auto-reference them — exactly what we
         want; RTAccess.csproj references them explicitly by path via RogueTraderManagedDir. -->
    <NoWarn>$(NoWarn);NU5128;NU5100</NoWarn>

    <PackageId>WH40KRT.GameRefs</PackageId>
    <!-- Stamped with the game version (see WH40KRT_Data/StreamingAssets/Version.info).
         Override on the command line: dotnet pack -p:Version=1.6.2.x -->
    <Version>1.6.1.514</Version>
    <Authors>alex19EP</Authors>
    <Description>Reference (metadata-only) assemblies for Warhammer 40,000: Rogue Trader, generated with JetBrains Refasmer (method bodies stripped). Build-time-only dependency for compiling the RTAccess accessibility mod in CI. Contains no game logic or resources.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/alex19EP/WH40KRTAccess</RepositoryUrl>
    <DevelopmentDependency>true</DevelopmentDependency>
  </PropertyGroup>
  <ItemGroup>
    <None Include="assemblies\*.dll" Pack="true" PackagePath="assemblies\" />
    <None Include="UnityModManager\*.dll" Pack="true" PackagePath="UnityModManager\" />
  </ItemGroup>
</Project>
